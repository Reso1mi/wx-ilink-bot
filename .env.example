# 微信 iLink Bot 配置

# 状态文件存储目录
BOT_STATE_DIR=./state

# 日志级别 (trace, debug, info, warn, error)
BOT_LOG_LEVEL=info

# iLink API 基础地址（通常不需要手动设置，登录后会自动更新）
# BOT_BASE_URL=https://ilinkai.weixin.qq.com

# App ID
BOT_APP_ID=bot

# 客户端版本号
BOT_VERSION=1.0.0

# HTTP 管理接口端口
BOT_HTTP_PORT=3000

# HTTP 管理接口对外暴露端口（仅 docker-compose 使用；被占用时可改为 3002 等）
BOT_HTTP_HOST_PORT=3001

# XHS-Downloader API 地址（本地运行建议使用 127.0.0.1；docker-compose 会自动覆盖为容器地址）
BOT_XHS_API_URL=http://127.0.0.1:5556

# XHS-Downloader 对外暴露端口（仅 docker-compose 使用）
BOT_XHS_API_PORT=5556

# Docker Compose 自定义 bridge 子网（如与 NAS 局域网/VPN 冲突，可改为 172.29.0.0/16 等）
BOT_DOCKER_SUBNET=172.28.0.0/16

# 小红书请求 Cookie（可选，建议配置以提升视频清晰度和稳定性）
# BOT_XHS_COOKIE=

# 小红书请求代理（可选）
# BOT_XHS_PROXY=http://127.0.0.1:10808

# XHS-Downloader API 超时时间（毫秒）
BOT_XHS_TIMEOUT_MS=60000
